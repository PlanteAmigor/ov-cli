#!/usr/bin/env bash
DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"
if [ ! -d "$VENV" ]; then
    VENV="$DIR/Hy-MT2/.venv"
fi
if [ ! -d "$VENV" ]; then
    VENV="$DIR/../.venv"
fi

if [ -d "$VENV" ]; then
    # 限定 PATH 只包含本项目虚拟环境，避免 subprocess 找到外部 Python
    export PATH="$VENV/bin:/usr/bin:/bin"
    exec "$VENV/bin/python" -m ov_cli "$@"
else
    exec python -m ov_cli "$@"
fi
